{
    "cli": {
        "version": ">= 3.0.0",
        "appVersionSource": "remote"
    },
    "build": {
        "development": {
            "developmentClient": true,
            "distribution": "internal",
            "android": {
                "buildType": "apk",
                "credentialsSource": "local"
            },
            "channel": "development"
        },
        "preview": {
            "distribution": "internal",
            "android": {
                "buildType": "apk"
            },
            "channel": "preview"
        },
        "production": {
            "android": {
                "buildType": "app-bundle",
                "autoIncrement": true
            },
            "channel": "production"
        }
    }
}