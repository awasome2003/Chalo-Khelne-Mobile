# Copy to `.env` and fill in. Expo exposes EXPO_PUBLIC_* vars to the app bundle.

# Sentry crash reporting (Phase 0). Leave blank to disable (init is a no-op).
EXPO_PUBLIC_SENTRY_DSN=

# App environment: development | staging | production.
# Drives the API base URL (src/api/api.js) and Sentry (only sends in production).
EXPO_PUBLIC_ENV=development

# Optional explicit API server override. If set, wins over EXPO_PUBLIC_ENV.
# Leave blank to use the per-env default (prod=chalokhelne.com,
# dev=auto-detected LAN IP). Example: http://192.168.1.50:3003
EXPO_PUBLIC_SERVER_URL=
